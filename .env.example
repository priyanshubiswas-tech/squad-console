# Copy this file to `.env` and fill in whatever API keys you have.
# Everything below already has working defaults for `docker compose up` on
# mock data — you only need to touch the blank keys once you reach the
# phase that needs them (see the root README's roadmap).

# --- API gateway ---
# Shared secret checked by both Nginx and the backend itself (defense in
# depth) - see README § Nginx + API key gate. Generate your own with:
#   python3 -c "import secrets; print(secrets.token_hex(24))"
API_KEY=changeme-generate-a-real-secret

# --- CORS ---
# Comma-separated browser origins allowed to hit the session-cookie flow
# (backend/app/main.py). Add your deployed frontend's origin here (e.g. a
# Vercel URL) alongside localhost:3000 for local dev.
CORS_ORIGINS=http://localhost:3000

# --- ClickHouse ---
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=changeme
CLICKHOUSE_MASTER_DB=squad_data_store

# --- ChromaDB (not wired up yet) ---
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_HOST_PORT=8001   # published to the host - what embedding_job/ (host-run) connects to

# --- LLM provider (used by the LangGraph reasoning node, not wired up yet) ---
LLM_PROVIDER=anthropic            # or openai, or google
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
LLM_MODEL=

# --- External data APIs (not wired up yet) ---
API_FOOTBALL_KEY=
THESPORTSDB_KEY=3                 # "3" is the public test key
NEWSAPI_KEY=
TRANSFERMARKT_API_BASE=http://transfermarkt-api:8000

# --- App config ---
TEAMS=england,france,brazil,argentina,spain,germany,portugal,capeverde
INGESTION_INTERVAL_HOURS=6
CHART_OUTPUT_DIR=/app/charts

# --- Manager identity mapping (used by the login page, no auth/passwords) ---
MANAGER_ENGLAND="Thomas Tuchel"
MANAGER_FRANCE="Didier Deschamps"
MANAGER_BRAZIL="Carlo Ancelotti"
MANAGER_ARGENTINA="Lionel Scaloni"
MANAGER_SPAIN="Luis de la Fuente"
MANAGER_GERMANY="Julian Nagelsmann"
MANAGER_PORTUGAL="Roberto Martinez"
MANAGER_CAPEVERDE="Bubista (Pedro Leitao Brito)"
